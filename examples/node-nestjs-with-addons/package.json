    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "@prisma/client": "^6.0.0",
    "ioredis": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "bullmq": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.4.0",
    "prisma": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.0"
